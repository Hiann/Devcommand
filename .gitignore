# ==========================================
# 1. DEPENDÊNCIAS (Muito pesadas, o git não precisa rastrear)
# ==========================================
/node_modules
/.pnp
.pnp.js

# ==========================================
# 2. PRODUÇÃO / BUILD (Arquivos gerados automaticamente)
# ==========================================
/build
/dist
/out

# ==========================================
# 3. VARIÁVEIS DE AMBIENTE (Segurança: Nunca comite chaves de API)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# 4. LOGS E DEBUG (Lixo gerado durante o desenvolvimento)
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ==========================================
# 5. TESTES (Relatórios de cobertura)
# ==========================================
/coverage

# ==========================================
# 6. SISTEMA OPERACIONAL (Arquivos ocultos que o Windows/Mac criam)
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==========================================
# 7. EDITORES E IDEs (Configurações locais do seu VS Code não devem ir pro repo)
# ==========================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?